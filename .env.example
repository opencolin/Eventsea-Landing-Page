# Eventsea landing page — environment variables
#
# Copy to `.env` (server) and/or `.env.local` (Vite, for VITE_* vars) and
# fill in real values. Anything starting with VITE_ is bundled into the
# client; everything else is server-only.

# -----------------------------------------------------------------------------
# AUDIT_WEBHOOK_URL
# -----------------------------------------------------------------------------
# Every POST /api/calendar-audit submission is forwarded here as JSON:
#   { "calendarUrl", "email", "auditType", "submittedAt" }
#
# Accepts a Slack-incoming-webhook-style URL (https://hooks.slack.com/...)
# or any HTTPS endpoint that returns 2xx (Resend, n8n, Zapier catch hook,
# your own /webhook handler, etc.).
#
# If unset, submissions still succeed and land in the in-memory store but
# the operator gets no notification — a structured warning is logged.
AUDIT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# VITE_CALENDLY_URL
# -----------------------------------------------------------------------------
# Public booking link surfaced by every "Book Demo" / "Skip the queue" CTA.
# Falls back to a mailto: link if unset.
#
# The founder will provide this. Format:
#   https://calendly.com/your-handle/15min
VITE_CALENDLY_URL=https://calendly.com/your-handle/15min

# -----------------------------------------------------------------------------
# EVENT_GATE_SECRET  (PRD v1, FR9)
# -----------------------------------------------------------------------------
# HMAC signing key for the per-event password-gate cookie (`es_event_<eventId>`).
# Server-only — never bundle into the client.
#
# Generate with:
#   openssl rand -hex 32
#
# Rotate quarterly (or whenever a secret leaks). Rotation invalidates every
# active gate cookie, which is the desired blast radius — sponsors re-login,
# nothing else breaks.
#
# Must be at least 32 chars. If unset or too short, the gate refuses to issue
# cookies and POST /d/:slug/login returns 500 — fail-closed by design.
EVENT_GATE_SECRET=

# -----------------------------------------------------------------------------
# EVENTSEA_BOOTSTRAP_TEST_EVENT  (optional, dev/smoke-test only)
# -----------------------------------------------------------------------------
# When set to any value, the in-memory storage seeds a deterministic test event
# (slug=test-slug, password=test-password) at startup so scripts/verify-gate.sh
# can hit a known event before Week 2 ingest lands. Leave unset in production.
EVENTSEA_BOOTSTRAP_TEST_EVENT=
